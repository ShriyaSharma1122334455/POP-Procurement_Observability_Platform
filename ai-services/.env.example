# Server
AI_SERVICE_PORT=8000
ENVIRONMENT=development

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# DynamoDB (local dev — point to local DynamoDB or leave blank for real AWS)
DYNAMODB_ENDPOINT=http://localhost:8001

# DynamoDB table names (defaults match pop-dev-* convention)
DYNAMODB_SUPPLIERS_TABLE=pop-dev-suppliers
DYNAMODB_PURCHASE_ORDERS_TABLE=pop-dev-purchase-orders
DYNAMODB_ALERTS_TABLE=pop-dev-alerts
DYNAMODB_SAVINGS_RECOMMENDATIONS_TABLE=pop-dev-savings-recommendations

# API Keys (loaded from Secrets Manager in production; set directly for local dev)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Secrets Manager secret names (used in production only)
ANTHROPIC_SECRET_NAME=pop/anthropic-api-key
OPENAI_SECRET_NAME=pop/openai-api-key
