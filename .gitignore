# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules
frontend/.pnp
.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions

# ── Build output ──────────────────────────────────────────────────────────────
dist
frontend/.next/
frontend/out/
frontend/build
frontend/coverage

# ── Environment & secrets ─────────────────────────────────────────────────────
.env*

# ── Next.js generated ─────────────────────────────────────────────────────────
frontend/next-env.d.ts

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Deployment ────────────────────────────────────────────────────────────────
.vercel

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
dist/

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Terraform ─────────────────────────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
# Keep the example file and the lock file (reproducible provider versions)
!*.tfvars.example
# Uncomment the next line if you want to ignore the lock file too:
# .terraform.lock.hcl

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
